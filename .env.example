# 复制本文件为 .env，然后填写自己的账号信息。
# 注意：.env 已加入 .gitignore，请不要把真实账号密码提交到仓库。

UESTC_USERNAME=your_student_or_staff_id
# 账号域默认使用 @dx-uestc，通常无需修改；如果 UESTC_USERNAME 已包含 @，不会重复追加。
# UESTC_ACCOUNT_DOMAIN=@dx-uestc
# 兼容旧配置名；设置 UESTC_USERNAME 后本项不会使用。
UESTC_PHONE=
UESTC_PASSWORD=your_password

# 可选配置
# UESTC_HOST=223.5.5.5
# UESTC_WAIT_TIME=15
# UESTC_MAX_RETRY_WAIT=300
# UESTC_PORTAL_URL=http://aaa.uestc.edu.cn/
# UESTC_HTTP_PROBE_URL=http://www.msftconnecttest.com/connecttest.txt
# UESTC_HTTP_PROBE_EXPECTED=Microsoft Connect Test
# UESTC_AC_ID=
# UESTC_DEBUG=0
# UESTC_VERIFY_TLS=1
# UESTC_ALLOW_INSECURE_HTTP=0
# UESTC_LOG_RESPONSE_BODY=0
